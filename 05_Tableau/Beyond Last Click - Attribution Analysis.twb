    <worksheet name='H6 | Best Time for Paid Ads'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#1b2a4a' fontname='Benton Sans Book' fontsize='14'>When Do Paid Ads Convert Best? (Day × Hour)</run>
            <run>Æ&#10;&#10;</run>
            <run fontcolor='#1b2a4a' fontname='Benton Sans Book' fontsize='12'>Conversion rates peak on Saturday 5–7am and Monday–Tuesday 14–16:00. </run>
            <run>Æ&#10;</run>
            <run fontcolor='#1b2a4a' fontname='Benton Sans Book' fontsize='12'>Avoid overnight weekday scheduling.</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='ab_testing_clean' name='federated.116va1f1s9dhbv1fhpx8t0c559cu' />
          </datasources>
          <datasource-dependencies datasource='federated.116va1f1s9dhbv1fhpx8t0c559cu'>
            <column caption='Paid Conv Rate H6' datatype='real' name='[Calculation_6249961084899337]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [test group] = &apos;ad&apos; AND [converted] = TRUE THEN 1 ELSE 0 END)&#10;/&#10;SUM(IF [test group] = &apos;ad&apos; THEN 1 ELSE 0 END)&#10;* 100' />
            </column>
            <column caption='Converted' datatype='boolean' name='[converted]' role='dimension' type='nominal' />
            <column caption='Most Ads Day' datatype='string' name='[most ads day]' role='dimension' type='nominal' />
            <column caption='Most Ads Hour' datatype='integer' name='[most ads hour]' role='measure' type='quantitative' />
            <column-instance column='[most ads day]' derivation='None' name='[none:most ads day:nk]' pivot='key' type='nominal' />
            <column-instance column='[most ads hour]' derivation='None' name='[none:most ads hour:qk]' pivot='key' type='quantitative' />
            <column caption='Test Group' datatype='string' name='[test group]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;ad&quot;' value='Paid Ads' />
                <alias key='&quot;psa&quot;' value='Organic' />
              </aliases>
            </column>
            <column-instance column='[Calculation_6249961084899337]' derivation='User' name='[usr:Calculation_6249961084899337:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <manual-sort column='[federated.116va1f1s9dhbv1fhpx8t0c559cu].[none:most ads day:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;Monday&quot;</bucket>
              <bucket>&quot;Tuesday&quot;</bucket>
              <bucket>&quot;Wednesday&quot;</bucket>
              <bucket>&quot;Thursday&quot;</bucket>
              <bucket>&quot;Friday&quot;</bucket>
              <bucket>&quot;Saturday&quot;</bucket>
              <bucket>&quot;Sunday&quot;</bucket>
            </dictionary>
          </manual-sort>
          <filter class='quantitative' column='[federated.116va1f1s9dhbv1fhpx8t0c559cu].[none:most ads hour:qk]' included-values='in-range'>
            <min>0</min>
            <max>23</max>
          </filter>
          <slices>
            <column>[federated.116va1f1s9dhbv1fhpx8t0c559cu].[none:most ads hour:qk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='axis'>
            <encoding attr='space' class='0' field='[federated.116va1f1s9dhbv1fhpx8t0c559cu].[none:most ads hour:qk]' field-type='quantitative' max='23' min='0' range-type='fixed' scope='cols' type='space' />
          </style-rule>
          <style-rule element='mark'>
            <encoding attr='color' field='[federated.116va1f1s9dhbv1fhpx8t0c559cu].[usr:Calculation_6249961084899337:qk]' max='4.0' min='1.5' num-steps='5' palette='orange_10_0' type='interpolated' />
          </style-rule>
        </style>
        <panes>
          <pane id='2' selection-relaxation-option='selection-relaxation-allow'>
            <view>
