      <aliases enabled='yes' />
      <column caption='Activity Level' datatype='string' name='[Calculation_1163002875338753]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [days_since_last_upload] &lt;= 30 THEN &quot;Very Active (≤30 days)&quot;&#10;   ELSEIF [days_since_last_upload] &lt;= 90 THEN &quot;Active (31-90 days)&quot;&#10;   ELSE &quot;Moderate (91-365 days)&quot;&#10;   END' />
      </column>
      <column caption='Quadrant' datatype='string' name='[Calculation_1163002904109058]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [view_per_subscriber] &gt;= 0.6334 AND [days_since_last_upload] &lt;= 30&#10;THEN &quot;High VPS · Recently Active&quot;&#10;ELSEIF [view_per_subscriber] &gt;= 0.6334 AND [days_since_last_upload] &gt; 30&#10;THEN &quot;High VPS · Less Active&quot;&#10;ELSEIF [view_per_subscriber] &lt; 0.6334 AND [days_since_last_upload] &lt;= 30&#10;THEN &quot;Low VPS · Recently Active&quot;&#10;ELSE &quot;Low VPS · Less Active&quot;&#10;END' />
      </column>
      <column caption='Channel Count' datatype='integer' name='[Calculation_6249961066274824]' role='measure' type='quantitative'>
